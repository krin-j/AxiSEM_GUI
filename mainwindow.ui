                </item>
                <item>
                 <widget class="QGroupBox" name="grpWavefieldScanning">
                  <property name="toolTip">
                   <string>AxiSEM3D learns a sub-optimal Nr(s,z) during simulation and dumps it to a file for re-use. It analyzes the Fourier series at mesh points upon energy peak arrival. To re-use: set type_Nr = POINTWISE and point nc_data_file to the scanning output.</string>
                  </property>
                  <property name="title">
                   <string>Wavefield Scanning</string>
                  </property>
                  <layout class="QFormLayout" name="formWavefieldScanning">
                   <item row="0" column="1">
                    <widget class="QCheckBox" name="checkWavefieldScanningOn">
                     <property name="text">
                      <string>Enable Scanning</string>
                     </property>
                    </widget>
                   </item>
                   <item row="1" column="0">
                    <widget class="QLabel" name="label_43">
                     <property name="toolTip">
                      <string>File path for the wavefield scanning output.</string>
                     </property>
                     <property name="text">
                      <string>Output File:</string>
                     </property>
                    </widget>
                   </item>
                   <item row="1" column="1">
                    <widget class="QLineEdit" name="lineWavefieldOutputFile"/>
                   </item>
                   <item row="2" column="0">
                    <widget class="QLabel" name="label_44">
                     <property name="toolTip">
                      <string>Accuracy loss by truncating the Fourier series of the wavefield. Allowed range: [1e-4, 1e-1].</string>
                     </property>
                     <property name="text">
                      <string>Threshold Fourier Conv:</string>
                     </property>
                    </widget>
                   </item>
                   <item row="2" column="1">
                    <widget class="QLineEdit" name="lineThresholdFourierConv"/>
                   </item>
                   <item row="3" column="0">
                    <widget class="QLabel" name="label_45">
                     <property name="toolTip">
                      <string>Peaks with amplitude smaller than this × largest peak are skipped. 1.0 = only largest peak, 0.0 = all peaks. Range: [0.0, 1.0].</string>
                     </property>
                     <property name="text">
                      <string>Relative Amp Skip:</string>
                     </property>
                    </widget>
                   </item>
                   <item row="3" column="1">
                    <widget class="QLineEdit" name="lineRelativeAmpSkip"/>
                   </item>
                   <item row="4" column="0">
                    <widget class="QLabel" name="label_47">
                     <property name="toolTip">
                      <string>Absolute amplitude threshold for skipping energy peaks. Allowed range: [1e-14, 1e-10].</string>
                     </property>
                     <property name="text">
                      <string>Absolute Amp Skip:</string>
                     </property>
                    </widget>
                   </item>
                   <item row="4" column="1">
                    <widget class="QLineEdit" name="lineAbsAmpSkip"/>
                   </item>
                   <item row="5" column="0">
                    <widget class="QLabel" name="label_48">
                     <property name="toolTip">
                      <string>Maximum number of energy peaks to consider. Use a small value to focus on only the largest peaks.</string>
                     </property>
                     <property name="text">
                      <string>Max Num Peaks:</string>
                     </property>
                    </widget>
                   </item>
                   <item row="5" column="1">
                    <widget class="QLineEdit" name="lineMaxNumPeaks"/>
                   </item>
                   <item row="6" column="1">
                    <widget class="QCheckBox" name="checkScanOnlyVertexGLL">
