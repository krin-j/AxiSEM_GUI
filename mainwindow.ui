                     <property name="toolTip">
                      <string>Cartesian mesh: structured_s (double, M), structured_z (double, N), structured_Nr (int, M×N). Spherical mesh: replace _s/_z with _r/_t (θ). Units: meters for s/z/r, radians for θ.</string>
                     </property>
                     <property name="text">
                      <string>NC Data File:</string>
                     </property>
